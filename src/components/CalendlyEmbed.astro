---
interface Props {
  type: 'consulta' | 'pareja';
}

const { type } = Astro.props;

const slug = type === 'pareja' ? 'primera-pareja' : 'primera-consulta';
const embedId = `reserva-maria-boadilla-del-monte-${slug}`;
const src = `https://panel.nutricionista.io/embed/cita/maria-boadilla-del-monte/${slug}`;
---

<div class="reserva-embed">
  <iframe
    id={embedId}
    src={src}
    width="100%"
    height="900"
    frameborder="0"
    style="border:0;width:100%"
    loading="lazy"
    title="Reservar cita"
    data-reserva-embed
  ></iframe>
</div>

<script>
  // El iframe publica su altura real para evitar scroll interno. Cada mensaje
  // se aplica solo al iframe que lo emitió (comparando contentWindow).
  addEventListener('message', (e: MessageEvent) => {
    if (!e || !e.data || e.data.type !== 'embed-reserva:height' || typeof e.data.height !== 'number') return;
    document.querySelectorAll<HTMLIFrameElement>('iframe[data-reserva-embed]').forEach((f) => {
      if (f.contentWindow === e.source) f.style.height = e.data.height + 'px';
    });
  });
</script>

<style>
  .reserva-embed {
    width: 100%;
    margin: var(--spacing-sm) 0;
  }

  .reserva-embed iframe {
    display: block;
    border-radius: var(--radius-md);
  }
</style>
